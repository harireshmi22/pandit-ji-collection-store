{
  "name": "pandit-ji-collection-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "docker:build": "docker build -t pandit-ji-collection .",
    "docker:run": "docker run -p 3000:3000 pandit-ji-collection",
    "seed:products": "node scripts/seed-database.js --count=20 --mode=replace",
    "seed:products:append": "node scripts/seed-database.js --count=20 --mode=append",
    "setup:perf": "node src/scripts/setup-performance.js",
    "db:indexes": "node -e \"require('./src/lib/mongodb-indexes.js').createIndexes()\"",
    "test:redis": "node src/scripts/test-redis.js"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "lucide-react": "^0.562.0",
    "mongoose": "^9.0.2",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.30",
    "razorpay": "^2.9.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "resend": "^6.9.3",
    "swiper": "^12.0.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4"
  }
}
